{
  "manifest_version": 3,
  "name": "Clipboard Inserter",
  "version": "1.0.2",
  "description": "Monitors clipboard for changes and inserts new text into the active page. For Japanese text hooking.",
  "permissions": [
    "clipboardRead",
    "offscreen",
    "storage",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["texthooker.html", "offscreen.html", "template-renderer.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "Clipboard Inserter (OFF) - Click to toggle",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "64": "icons/icon64.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "64": "icons/icon64.png"
  }
}